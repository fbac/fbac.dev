---
const projects = [
  {
    name: 'sklookup-go',
    url: 'https://github.com/fbac/sklookup-go',
    description: 'eBPF sk_lookup as a Go library for steering network connections',
    tags: ['Go', 'eBPF', 'Linux'],
  },
  {
    name: 'skproxy',
    url: 'https://github.com/fbac/skproxy',
    description: 'L4 proxy with eBPF socket steering and load balancing',
    tags: ['Go', 'eBPF'],
  },
  {
    name: 'zkproof-go',
    url: 'https://github.com/fbac/zkproof-go',
    description: 'Zero-knowledge proof (Chaum-Pedersen) gRPC authentication server',
    tags: ['Go', 'ZK', 'gRPC'],
  },
  {
    name: 'xmtpd',
    url: 'https://github.com/xmtp/xmtpd',
    description: 'Decentralized messaging node powering the XMTP network',
    tags: ['Go', 'Rust', 'PostgreSQL'],
  },
];
---

<section class="projects">
  <h2><span class="prefix">// </span>Projects</h2>
  <div class="grid">
    {projects.map((project) => (
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="card">
        <h3>{project.name}</h3>
        <p>{project.description}</p>
        <div class="tags">
          {project.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .projects {
    padding: var(--section-gap) 0;
  }

  h2 {
    font-size: 1.4rem;
    margin-bottom: 1.5rem;
  }

  .prefix {
    color: var(--color-accent);
    opacity: 0.7;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    transition: background var(--transition-fast);
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card:hover {
    background: var(--color-bg-card-hover);
  }

  h3 {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-dim);
    background: var(--color-accent-dim);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
</style>

---
import SocialLinks from './SocialLinks.astro';
---

<header class="header">
  <div class="identity">
    <img src="/img/avatar.png" alt="Borja Aranda" class="avatar" />
    <div class="info">
      <h1>Borja Aranda</h1>
      <p class="subtitle">Staff Engineer</p>
      <p class="subtitle">Distributed Systems</p>
      <p class="subtitle">Protocol Engineering</p>
    </div>
  </div>
  <SocialLinks />
</header>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .identity {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 12px rgba(245, 158, 11, 0.15);
  }

  h1 {
    font-size: 1.4rem;
    margin-bottom: 0.15rem;
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 600px) {
    .header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
  }
</style>

---
import SocialLinks from './SocialLinks.astro';
---

<section class="hero">
  <img src="/img/avatar.png" alt="Borja Aranda" class="avatar" />
  <h1>Borja Aranda</h1>
  <p class="role">Staff Engineer</p>
  <hr class="divider" />
  <p class="focus">Distributed Systems · Protocol Engineering · Infrastructure</p>
  <p class="summary">15+ years building low-level protocols, distributed backends, and production infrastructure — from Linux kernel and Kubernetes at Red Hat to decentralized protocol architectures at XMTP, Chainlink, and ZetaChain.</p>
  <SocialLinks />
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem 1rem;
  }

  .avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    letter-spacing: -0.03em;
    margin-bottom: 0.25rem;
  }

  .role {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .divider {
    width: 3rem;
    border: none;
    border-top: 2px solid var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .focus {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
  }

  .summary {
    max-width: 520px;
    font-size: 0.95rem;
    color: var(--color-text-dim);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 2rem;
    }

    .summary {
      max-width: 100%;
    }
  }
</style>

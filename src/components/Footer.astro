---
const year = new Date().getFullYear();
---

<footer>
  <hr />
  <p>&copy; {year} Borja Aranda Castillejo</p>
  <p class="built-with">Built with <a href="https://astro.build/" target="_blank" rel="noopener noreferrer">Astro</a></p>
</footer>

<style>
  footer {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-accent);
    opacity: 0.3;
    margin-bottom: 1.5rem;
  }

  p {
    font-size: 0.8rem;
    color: var(--color-text-dim);
  }

  .built-with {
    margin-top: 0.5rem;
    font-size: 0.75rem;
  }
</style>

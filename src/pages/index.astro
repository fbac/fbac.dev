---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
---

<Layout>
  <main>
    <Hero />
    <About />
  </main>

  <style>
    main {
      max-width: var(--content-max-width);
      margin: 0 auto;
      padding: 0 1.5rem;
    }
  </style>
</Layout>
